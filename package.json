    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource/atkinson-hyperlegible": "^5.2.8",
    "@inlang/paraglide-js": "^2.20.2",
    "@sveltejs/vite-plugin-svelte": "^7.1.4",
    "gh-pages": "^6.1.1",
    "svelte": "^5.56.4",
    "vite": "^8.1.3"
  }
}
