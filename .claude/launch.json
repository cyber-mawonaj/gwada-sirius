{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "gwada-sirius-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 8080
    },
    {
      "name": "gwada-sirius-preview",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["eleventy", "--serve", "--port=8099"],
